# QuantGod split-repo line-ending policy.
# Keep source files reviewable on GitHub raw views and safe for CI.

* text=auto

*.py text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.mq5 text eol=lf
*.set text eol=lf
*.ini text eol=lf

*.bat text eol=crlf
*.ps1 text eol=crlf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.ex4 binary
*.ex5 binary
