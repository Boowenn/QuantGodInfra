{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "quantgod-cloud",
  "main": "src/index.js",
  "compatibility_date": "2026-04-20",
  "assets": {
    "directory": "../Dashboard",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
