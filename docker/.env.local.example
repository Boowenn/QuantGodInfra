# QuantGod local-only Docker Compose ports and optional P3-2 Telegram push-only config.
# Copy this file to docker/.env.local. Keep docker/.env.local uncommitted.
QG_BACKEND_PORT=8080
QG_FRONTEND_PORT=5173
COMPOSE_PROJECT_NAME=quantgod-local-dev

# P3-2 Telegram push-only: disabled by default.
# Token comes from @BotFather. Chat ID can be discovered by Backend tools/run_telegram_notifier.py link.
QG_TELEGRAM_PUSH_ALLOWED=0
QG_TELEGRAM_COMMANDS_ALLOWED=0
QG_TELEGRAM_BOT_TOKEN=
QG_TELEGRAM_CHAT_ID=
QG_TELEGRAM_API_BASE_URL=https://api.telegram.org
